# OpenAI API key (required for Stage 2 summarization)
OPENAI_API_KEY=

# YouTube and Apify keys are handled by utils-youtube — see its .env.example

# Path to the shared SQLite database (default: ../../data/artimesone.db)
DB_PATH=../../data/artimesone.db

# Directory for daily rollup markdown output (default: ../../data/agent-youtube-summary)
ROLLUP_OUTPUT_DIR=../../data/agent-youtube-summary
